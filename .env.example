# Copy to .env and adjust as needed.
SENTIANCE_APP_NAME=Sentiance
SENTIANCE_ENVIRONMENT=development
SENTIANCE_LOG_LEVEL=INFO

# Event bus: "memory" (in-process) or "kafka"
SENTIANCE_BUS_BACKEND=memory
SENTIANCE_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SENTIANCE_KAFKA_GROUP_ID=sentiance

# Segment store: leave unset for in-memory; set for the Postgres adapter.
# SENTIANCE_POSTGRES_DSN=postgresql://sentiance:sentiance@localhost:5432/sentiance

# Feature extraction
SENTIANCE_WINDOW_SECONDS=5.0
SENTIANCE_MIN_SAMPLES_PER_WINDOW=16

# Segmentation hysteresis (windows required to switch activity)
SENTIANCE_SEGMENT_SWITCH_WINDOWS=2
