# Copy to .env and adjust as needed. `.env` is gitignored — secrets never commit.
# Everything here is loaded into the environment at startup (CLI + training
# scripts); a real shell variable always wins over a value set here.

# --- Hugging Face -----------------------------------------------------------
# Your HF access token (https://huggingface.co/settings/tokens — a read-only
# "Read" token is enough). Silences the "unauthenticated requests" warning and
# lifts download rate limits when the finetuned/fused backends and the training
# scripts fetch a base model. Leave blank to stay anonymous.
HF_TOKEN=

SENTIANCE_APP_NAME=Sentiance
SENTIANCE_ENVIRONMENT=development
SENTIANCE_LOG_LEVEL=INFO

# The mind's identity (used in first-person self-report)
SENTIANCE_AGENT_NAME=Aria

# Where chat persists the mind across runs (default: ./memory/<name>.json)
# SENTIANCE_PERSIST_PATH=memory/aria.json

# Affect dynamics
SENTIANCE_MOOD_INERTIA=0.9
SENTIANCE_EMOTION_DECAY=0.6

# Attention: softmax temperature for the salience competition (lower = sharper)
SENTIANCE_ATTENTION_TEMPERATURE=0.5

# Memory
SENTIANCE_WORKING_MEMORY_SIZE=7
SENTIANCE_EPISODIC_CAPACITY=500

# Cognition backend: "simulated" (offline) · "llm" (Anthropic) · "ollama" (local)
# · "finetuned" (Path A voice) · "fused" (Path B, cognition-conditioned)
SENTIANCE_COGNITION_BACKEND=simulated
SENTIANCE_LLM_MAX_TOKENS=256

# Trained-model locations (finetuned / fused backends) + the base they adapt.
# SENTIANCE_LOCAL_MODEL_PATH=models/sentiance-voice
# SENTIANCE_FUSED_MODEL_PATH=models/sentiance-fused
# SENTIANCE_LOCAL_BASE_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# "llm" backend (Anthropic)
SENTIANCE_LLM_MODEL=claude-opus-4-8
# Falls back to the standard ANTHROPIC_API_KEY if unset.
# SENTIANCE_ANTHROPIC_API_KEY=sk-ant-...

# "ollama" backend (local model — no key, nothing leaves the machine)
SENTIANCE_OLLAMA_MODEL=qwen2.5:7b
SENTIANCE_OLLAMA_BASE_URL=http://localhost:11434

# Associative memory: "none" (recall by shared words) or "ollama" (by meaning).
# For "ollama", first: ollama pull nomic-embed-text
SENTIANCE_EMBEDDING_BACKEND=none
SENTIANCE_EMBEDDING_MODEL=nomic-embed-text

